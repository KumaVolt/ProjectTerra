# ProjectTerra Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# At least one LLM API key is required (either or both):

# Anthropic Claude API (optional)
ANTHROPIC_API_KEY=

# Zhipu AI GLM / z.ai API (optional)
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# Terra self-hosted model server (auto-set once model is usable)
# TERRA_SERVER_URL=http://localhost:8080

# GitHub (auto-set in GitHub Actions, only needed for local issue tracking)
# GITHUB_REPOSITORY=your-username/ProjectTerra
# GITHUB_TOKEN=

# External GPU compute (optional, for cloud training bursts)
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# RUNPOD_API_KEY=

# HuggingFace Hub (for cloud training checkpoint uploads)
# HF_TOKEN=
# HF_REPO_ID=your-username/terra-checkpoints
